# Supabase Edge Function Secrets
# Configure via: supabase secrets set KEY=value
# Ou via Dashboard > Edge Functions > Secrets

# Obrigatório para análise corporal e colorimetria
LOVABLE_API_KEY=your_lovable_api_key_here

# Obrigatório para provador virtual (FASHN AI)
# Obtenha em: https://fashn.ai/products/api → Developer Dashboard
FASHN_API_KEY=your_fashn_api_key_here

# Opcional: melhora extração de dados de produtos (tabela de medidas, imagens)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Obrigatório para sistema de quotas (service role, não expor no frontend!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
